{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 26, "patch": 0 },
  "configurePresets": [
    {
      "name": "windows-x64-release",
      "displayName": "Windows x64 Release",
      "generator": "Visual Studio 18 2026",
      "architecture": { "value": "x64", "strategy": "set" },
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-windows-static",
        "FL_DEBUG_TRIGGERS": "OFF",
        "FL_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "windows-x64-debug",
      "inherits": "windows-x64-release",
      "displayName": "Windows x64 Debug (synthetic triggers ON)",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "FL_DEBUG_TRIGGERS": "ON"
      }
    },
    {
      "name": "windows-x64-test",
      "inherits": "windows-x64-release",
      "displayName": "Windows x64 Release + synthetic triggers (field testing)",
      "binaryDir": "${sourceDir}/build/test",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "FL_DEBUG_TRIGGERS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-x64-release",
      "configurePreset": "windows-x64-release",
      "configuration": "Release"
    },
    {
      "name": "windows-x64-debug",
      "configurePreset": "windows-x64-debug",
      "configuration": "Debug"
    },
    {
      "name": "windows-x64-test",
      "configurePreset": "windows-x64-test",
      "configuration": "Release"
    }
  ],
  "testPresets": [
    {
      "name": "windows-x64-release",
      "configurePreset": "windows-x64-release",
      "configuration": "Release",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "windows-x64-debug",
      "configurePreset": "windows-x64-debug",
      "configuration": "Debug",
      "output": { "outputOnFailure": true }
    }
  ]
}
